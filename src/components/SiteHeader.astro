---
/**
 * Header at top of site.
 */
---
<nav class="bg-[#0089CC] text-white h-12 flex items-center relative z-50 shadow-sm w-full shrink-0 px-4 justify-between">
	<div class="flex items-center space-x-2">
		<button
			data-dialog="info"
			class="dialog-open hover:cursor-pointer text-white hover:text-[#c1ffdc] transition-colors p-1"
			title="About DoctorPricer"
		>
			<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"
				><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
				></path></svg
			>
		</button>
		<a href="/" class="text-white text-[20px] md:text-[24px] font-normal hover:text-white truncate"> DoctorPricer </a>
	</div>

	<slot name="header" />
</nav>
