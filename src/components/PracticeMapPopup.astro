---
/**
 * Popup template used it PracticeMap.astro
 */
---

<template id="popup-content-template">
	<div class="p-1 min-w-50">
		<h5 class="name-display font-bold text-lg m-0 leading-tight mb-2"></h5>

		<p class="address-wrapper text-sm m-0 mt-1 flex items-start gap-1 text-gray-700">
			<svg class="w-3.5 h-3.5 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"
				><path
					stroke-linecap="round"
					stroke-linejoin="round"
					stroke-width="2"
					d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"
				></path></svg
			>
			<span class="address-display block w-full leading-tight"></span>
		</p>

		<p class="phone-wrapper text-sm m-0 mt-1.5 flex items-center gap-1 text-gray-700">
			<svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"
				><path
					stroke-linecap="round"
					stroke-linejoin="round"
					stroke-width="2"
					d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
				></path></svg
			>
			<span class="phone-display"></span>
		</p>

		<p class="website-wrapper text-sm m-0 mt-1.5 flex items-center gap-1 text-[#337ab7] hidden hover:text-[#286090]">
			<svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"
				><path
					stroke-linecap="round"
					stroke-linejoin="round"
					stroke-width="2"
					d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"
				></path></svg
			>
			<a class="website-display truncate block w-full hover:underline" target="_blank" rel="noopener noreferrer">Visit Website</a>
		</p>

		<p class="pho-display text-xs text-gray-500 m-0 mt-2 pt-2 border-t border-gray-100"></p>
		<p class="enrolling-status text-xs text-red-600 font-bold m-0 mt-1 uppercase tracking-wide hidden">Not Enrolling</p>
		<p class="restricted text-xs text-orange-600 font-bold m-0 mt-1 uppercase tracking-wide hidden">Restrictions may apply</p>
	</div>
</template>
