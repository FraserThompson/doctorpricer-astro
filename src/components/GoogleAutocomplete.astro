---
export interface Props {
	size?: 'large' | 'small';
}
const { size = 'large' } = Astro.props;
---

<google-autocomplete class="block w-full" data-size={size}>
	<div class="autocomplete-container relative w-full">
		<div
			class="skeleton-loader w-full border bg-gray-50 text-gray-400 border-gray-300 rounded shadow-sm flex items-center justify-between box-border"
			style={size === 'large' ? 'padding: 0 1rem; height: 54px;' : 'padding: 0 0.75rem; height: 38px;'}
		>
			<svg class="w-5 h-5 animate-pulse" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
			</svg>
		</div>
	</div>
</google-autocomplete>

<script>
	import { searchStore } from '../store/appStore';
	import { PLACE_AUTOCOMPLETE_FIELDS } from '../services/placeSelection';

	class GoogleAutocomplete extends HTMLElement {
		private container!: HTMLDivElement;
		private retries = 0;
		private maxRetries = 50;
		private placeAutocomplete: any = null;

		connectedCallback() {
			this.container = this.querySelector('.autocomplete-container') as HTMLDivElement;
			this.initWhenReady();
		}

		private async initWhenReady() {
			const isMapsLoaded = window.google && window.google.maps && window.google.maps.places;
			const isComponentLoaded = isMapsLoaded && (window as any).google.maps.places.PlaceAutocompleteElement;

			if (typeof window === 'undefined' || !isComponentLoaded) {
				this.retries++;
				if (this.retries > this.maxRetries) {
					console.error('Google Maps Places API failed to load in time.');
					this.container.innerHTML = `<input type="text" disabled placeholder="Failed to load address search." class="w-full p-4 border bg-gray-50 border-gray-300 rounded opacity-50 box-border" />`;
					return;
				}
				// Check again in 100ms
				setTimeout(() => this.initWhenReady(), 100);
				return;
			}

			this.setupAutocomplete();
		}

		private async setupAutocomplete() {
			const PlaceAutocompleteElement = (window as any).google.maps.places.PlaceAutocompleteElement;

			this.placeAutocomplete = new PlaceAutocompleteElement({
				includedRegionCodes: ['nz'],
			});

			this.placeAutocomplete.placeholder = 'Type an address...';

			this.placeAutocomplete.className = 'block w-full bg-white text-gray-900 border border-gray-300 rounded shadow-sm box-border';

			const isLarge = this.dataset.size === 'large';
			this.placeAutocomplete.style.height = isLarge ? '54px' : '34px';
			this.placeAutocomplete.style.fontSize = isLarge ? '1.125rem' : '0.875rem';

			this.container.innerHTML = '';
			this.container.appendChild(this.placeAutocomplete);

			const initialState = searchStore.get();
			if (initialState?.displayAddress) {
				this.placeAutocomplete.value = initialState.displayAddress;
			}

			searchStore.subscribe((state) => {
				if (!state || !this.placeAutocomplete) return;

				// Update the input if the store changed, but NOT if the user is actively typing in it
				if (state.displayAddress && !this.placeAutocomplete.contains(document.activeElement)) {
					this.placeAutocomplete.value = state.displayAddress;
				}
			});

			this.placeAutocomplete.addEventListener('keydown', (e: KeyboardEvent) => {
				if (e.key === 'Enter') e.preventDefault();
			});

			this.placeAutocomplete.addEventListener('gmp-select', async (e: any) => {
				const place = e.placePrediction.toPlace();
				await place.fetchFields({ fields: PLACE_AUTOCOMPLETE_FIELDS });

				this.dispatchEvent(
					new CustomEvent('place-selected', {
						detail: { place },
						bubbles: true,
						composed: true,
					}),
				);
			});
		}
	}

	customElements.define('google-autocomplete', GoogleAutocomplete);
</script>
