---
export interface Props {
	size?: "large" | "small";
}
const { size = "large" } = Astro.props;

const paddingAndText = size === "large" ? "p-4 text-lg" : "px-3 py-1.5 text-sm";
const iconSize =
	size === "large" ? "w-6 h-6 right-4 top-4" : "w-4 h-4 right-2 top-2.5";
---

<google-autocomplete class="block w-full">
	<div class="relative">
		<input
			type="text"
			class={`autocomplete-input w-full p-4 border bg-white text-black border-gray-300 rounded shadow-sm text-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors opacity-50 ${paddingAndText}`}
			placeholder="Loading map data..."
			disabled
			required
		/>
		<svg
			class={`absolute text-gray-400 ${iconSize}`}
			fill="none"
			stroke="currentColor"
			viewBox="0 0 24 24"
		>
			<path
				stroke-linecap="round"
				stroke-linejoin="round"
				stroke-width="2"
				d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
		</svg>
	</div>
</google-autocomplete>

<script>
	class GoogleAutocomplete extends HTMLElement {
		private input!: HTMLInputElement;
		private maxRetries = 50;
		private retries = 0;

		connectedCallback() {
			this.input = this.querySelector(
				".autocomplete-input",
			) as HTMLInputElement;
			this.initWhenReady();
		}

		private initWhenReady() {
			if (
				typeof window === "undefined" ||
				!window.google ||
				!window.google.maps ||
				!window.google.maps.places
			) {
				this.retries++;
				if (this.retries > this.maxRetries) {
					console.error("Google Maps Places API failed to load.");
					this.input.placeholder = "Failed to load address search.";
					return;
				}
				setTimeout(() => this.initWhenReady(), 100);
				return;
			}
			this.setupAutocomplete();
		}

		private setupAutocomplete() {
			this.input.disabled = false;
			this.input.classList.remove("opacity-50");
			this.input.placeholder = "Start typing an address...";

			const autocomplete = new window.google.maps.places.Autocomplete(
				this.input,
				{
					componentRestrictions: { country: "nz" },
					fields: ["address_components", "geometry", "formatted_address"],
				},
			);

			// Prevent the actual form from submitting so we can handle the API fallback
			this.input.addEventListener("keydown", (e: KeyboardEvent) => {
				if (e.key === "Enter") e.preventDefault();
			});

			autocomplete.addListener("place_changed", () => {
				const place = autocomplete.getPlace();

				// SCENARIO 1: The user selected a valid item from the dropdown
				if (place.geometry && place.address_components) {
					this.dispatchPlace(place);
					return;
				}

				// SCENARIO 2: The user hit enter without selecting an item (The "watchEnter" fallback)
				const inputValue = this.input.value;
				if (!inputValue) return;

				const autocompleteService =
					new window.google.maps.places.AutocompleteService();

				autocompleteService.getPlacePredictions(
					{ input: inputValue, componentRestrictions: { country: "nz" } },
					(predictions: any, status: any) => {
						if (
							status !== window.google.maps.places.PlacesServiceStatus.OK ||
							!predictions ||
							predictions.length === 0
						) {
							console.warn("No predictions found for input:", inputValue);
							return;
						}

						// Grab the top prediction's ID
						const topPrediction = predictions[0];

						// PlacesService requires a DOM element to initialize, so we create a dummy div
						const placesService = new window.google.maps.places.PlacesService(
							document.createElement("div"),
						);

						placesService.getDetails(
							{
								placeId: topPrediction.place_id,
								fields: ["address_components", "geometry", "formatted_address"],
							},
							(detailsResult: any, detailsStatus: any) => {
								if (
									detailsStatus ===
										window.google.maps.places.PlacesServiceStatus.OK &&
									detailsResult
								) {
									// Revert the input text to match the correctly formatted address
									this.input.value =
										detailsResult.formatted_address || inputValue;

									// Dispatch the top prediction as if they had clicked it
									this.dispatchPlace(detailsResult);
								}
							},
						);
					},
				);
			});
		}

		private dispatchPlace(place: any) {
			this.dispatchEvent(
				new CustomEvent("place-selected", {
					detail: { place },
					bubbles: true,
					composed: true,
				}),
			);
		}
	}

	customElements.define("google-autocomplete", GoogleAutocomplete);
</script>
