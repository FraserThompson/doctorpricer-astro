---
import GoogleAutocomplete from './GoogleAutocomplete.astro';
---

<doctor-search-form class="flex h-full items-center justify-center">
	<div class="w-[90%] max-w-[500px] text-center pb-24">
		<h3 class="text-2xl font-medium mb-6 text-gray-800">Compare fees from 1000+ NZ medical practices.</h3>

		<form id="search-form" class="space-y-4">
			<div class="w-full">
				<GoogleAutocomplete />
			</div>

			<div class="w-full">
				<label class="sr-only" for="age">Age</label>
				<input
					id="age"
					type="number"
					min="0"
					class="w-full px-4 py-3 border border-gray-300 rounded-md shadow-inner focus:outline-none focus:ring-2 focus:ring-[#66afe9] focus:border-[#66afe9] transition-colors bg-white text-gray-700 placeholder-gray-400"
					placeholder="Age"
					autocomplete="off"
					required
				/>
			</div>

			<div class="flex flex-col sm:flex-row sm:items-center justify-between text-left py-2 px-1">
				<h4 class="text-[16px] font-bold m-0 sm:mr-4">
					Do you have a <a
						href="https://www.workandincome.govt.nz/products/a-z-benefits/community-services-card.html"
						target="_blank"
						rel="noopener noreferrer"
						class="text-[#337ab7] hover:underline hover:text-[#23527c]"
					>
						Community Services Card?
					</a>
				</h4>
				<div class="flex space-x-4 mt-2 sm:mt-0">
					<label class="flex items-center space-x-1 cursor-pointer text-[18px]">
						<input type="radio" name="csc" value="1" class="w-4 h-4 text-[#0089CC] focus:ring-[#0089CC]" />
						<span>Yes</span>
					</label>
					<label class="flex items-center space-x-1 cursor-pointer text-[18px]">
						<input type="radio" name="csc" value="0" class="w-4 h-4 text-[#0089CC] focus:ring-[#0089CC]" checked />
						<span>No</span>
					</label>
				</div>
			</div>

			<div class="w-full pt-2">
				<button
					type="submit"
					class="w-full text-center px-4 py-[10px] text-lg rounded-md text-white bg-[#28A15D] border border-[#036D31] hover:bg-[#118945] focus:bg-[#118945] transition-colors shadow-sm cursor-pointer"
				>
					Find Practices
				</button>
			</div>
		</form>
	</div>
</doctor-search-form>

<script>
	import { toResolvedSearchLocation, type PlaceSelection } from '../services/placeSelection';

	class DoctorSearchForm extends HTMLElement {
		private selectedPlace: PlaceSelection | null = null;

		connectedCallback() {
			// Listen for the event emitted by our Autocomplete component
			this.addEventListener('place-selected', (e: Event) => {
				const details = (e as CustomEvent).detail as { place?: PlaceSelection };
				this.selectedPlace = details.place || null;
			});

			this.querySelector('#search-form')?.addEventListener('submit', (e) => {
				e.preventDefault();
				this.handleSubmit();
			});
		}

		handleSubmit() {
			if (!this.selectedPlace) {
				return;
			}

			const { lat, lng, address, displayAddress } = toResolvedSearchLocation(this.selectedPlace);

			const ageEl: HTMLInputElement | null = this.querySelector('#age');
			const cscEl: HTMLInputElement | null = this.querySelector('input[name="csc"]:checked');
			const age = ageEl?.value || '10';
			const csc = cscEl?.value || '0';

			const queryParams = new URLSearchParams({
				lat: lat.toString(),
				lng: lng.toString(),
				age: age,
				csc: csc,
				address: address,
				displayAddress: displayAddress,
			});

			window.location.href = `/result?${queryParams.toString()}`;
		}
	}

	customElements.define('doctor-search-form', DoctorSearchForm);
</script>
