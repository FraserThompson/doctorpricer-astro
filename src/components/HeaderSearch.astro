---
/**
 * HeaderSearch.astro
 *
 * A search component to display in the navbar.
 */
import GoogleAutocomplete from './GoogleAutocomplete.astro';
---

<header-search class="flex items-center">
	<button id="mobile-search-toggle" class="md:hidden text-white p-2 hover:text-gray-200">
		<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"
			><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg
		>
	</button>

	<form id="desktop-header-form" class="hidden md:flex items-center space-x-2 w-full max-w-2xl ml-4">
		<div class="w-64">
			<GoogleAutocomplete size="small" />
		</div>
		<input
			type="number"
			name="age"
			class="w-16 px-2 py-1.5 text-sm border bg-white border-gray-300 rounded text-gray-800"
			placeholder="Age"
			autocomplete="off"
			required
		/>
		<label class="flex items-center space-x-1 text-sm text-white cursor-pointer whitespace-nowrap">
			<input type="checkbox" name="csc" class="w-4 h-4 rounded text-[#28A15D] focus:ring-[#28A15D]" />
			<span>CSC</span>
		</label>
		<button type="submit" class="bg-[#28A15D] hover:bg-[#118945] text-white px-3 py-1.5 text-sm rounded shadow-sm transition-colors">
			Search
		</button>
	</form>

	<dialog id="mobile-search-modal" class="backdrop:bg-black/60 p-0 rounded-lg shadow-2xl w-11/12 max-w-sm m-auto">
		<div class="bg-white p-5 rounded-lg">
			<div class="flex justify-between items-center mb-4">
				<h3 class="text-lg font-bold text-gray-800 m-0">Change Search</h3>
				<button id="close-mobile-search" type="button" class="text-gray-500 hover:text-gray-800">
					<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"
						><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg
					>
				</button>
			</div>

			<form id="mobile-header-form" class="space-y-4">
				<GoogleAutocomplete size="large" />
				<input
					type="number"
					name="age"
					class="w-full px-4 py-3 border border-gray-300 rounded text-lg text-gray-800"
					placeholder="Age"
					required
				/>
				<label class="flex items-center space-x-2 text-lg text-gray-800 cursor-pointer p-2 bg-gray-50 rounded border border-gray-200">
					<input type="checkbox" name="csc" class="w-5 h-5 rounded text-[#337ab7] focus:ring-[#337ab7]" />
					<span>I have a Community Services Card</span>
				</label>
				<button type="submit" class="w-full bg-[#28A15D] text-white px-4 py-3 text-lg rounded shadow-sm font-medium mt-2">
					Update Results
				</button>
			</form>
		</div>
	</dialog>
</header-search>

<script>
	import { searchStore } from '../store/appStore';
	import { fetchPractices } from '../services/practices';

	class HeaderSearch extends HTMLElement {
		private activePlace: any = null;

		connectedCallback() {
			const desktopForm = this.querySelector('#desktop-header-form') as HTMLFormElement;
			const mobileForm = this.querySelector('#mobile-header-form') as HTMLFormElement;
			const modal = this.querySelector('#mobile-search-modal') as HTMLDialogElement;

			this.querySelector('#mobile-search-toggle')?.addEventListener('click', () => modal.showModal());
			this.querySelector('#close-mobile-search')?.addEventListener('click', () => modal.close());

			const handleSubmit = async (e: SubmitEvent, form: HTMLFormElement) => {
				e.preventDefault();

				const age = parseInt((form.querySelector('input[name="age"]') as HTMLInputElement).value, 10);
				const csc = (form.querySelector('input[name="csc"]') as HTMLInputElement).checked;
				const autoInput = form.querySelector('.autocomplete-input') as HTMLInputElement;

				const currentSearch = searchStore.get();
				const typedAddress = autoInput?.value?.trim();

				const isPlaceValid =
					this.activePlace && (typedAddress === this.activePlace.formatted_address || typedAddress === this.activePlace.name);

				const isSameAsCurrentStore = typedAddress === currentSearch?.displayAddress;

				if (!isPlaceValid && !isSameAsCurrentStore && typedAddress !== '') {
					alert('Please select a specific location from the dropdown suggestions.');
					autoInput.focus();
					return;
				}

				const lat = isPlaceValid ? this.activePlace.geometry.location.lat() : currentSearch?.lat;
				const lng = isPlaceValid ? this.activePlace.geometry.location.lng() : currentSearch?.lng;
				const address = isPlaceValid ? this.activePlace.formatted_address : currentSearch?.address;

				const displayAddress = isPlaceValid ? this.activePlace.formatted_address : currentSearch?.displayAddress;

				if (!lat || !lng) {
					alert('Please select a valid address from the dropdown.');
					return;
				}

				// Update all keys in the store
				searchStore.set({ ...currentSearch, lat, lng, age, csc, address, displayAddress });
				await fetchPractices(lat, lng, age, csc ? 1 : 0, 0);

				this.activePlace = null;
				modal.close();
			};

			[desktopForm, mobileForm].forEach((form) => {
				if (!form) return;

				form.addEventListener('submit', (e) => handleSubmit(e as SubmitEvent, form));

				const cscInput = form.querySelector('input[name="csc"]') as HTMLInputElement;
				cscInput?.addEventListener('change', () => form.requestSubmit());
			});

			searchStore.subscribe((state) => {
				if (!state) return;
				[desktopForm, mobileForm].forEach((form) => {
					if (!form) return;
					const ageInput = form.querySelector('input[name="age"]') as HTMLInputElement;
					const cscInput = form.querySelector('input[name="csc"]') as HTMLInputElement;
					const autoInput = form.querySelector('.autocomplete-input') as HTMLInputElement;

					if (ageInput && state.age) ageInput.value = state.age.toString();
					if (cscInput) cscInput.checked = !!state.csc;

					if (autoInput && state.displayAddress && document.activeElement !== autoInput) {
						autoInput.value = state.displayAddress;
					}
				});
			});

			this.addEventListener('place-selected', ((e: CustomEvent) => {
				this.activePlace = e.detail.place;
				this.querySelector('form')?.requestSubmit();
			}) as EventListener);
		}
	}

	customElements.define('header-search', HeaderSearch);
</script>
